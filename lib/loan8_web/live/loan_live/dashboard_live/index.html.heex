        </div>

        <div>
          KES 75,000
        </div>

        <div class="text-green-600 font-bold">
          KES 12,941
        </div>

        <div>
          <span class="bg-slate-100 px-4 py-2 rounded-full text-sm">
            6 months
          </span>
        </div>

        <div>
          12.0%
        </div>

        <div>
          22 Apr 2026
        </div>

      </div>

      

      <div class="grid grid-cols-7 gap-4 items-center px-8 py-6 border-b border-slate-100 hover:bg-slate-50">

        <div class="col-span-2 font-semibold text-lg">
          Shop stock top-up
        </div>

        <div>
          KES 320,000
        </div>

        <div class="text-green-600 font-bold">
          KES 19,813
        </div>

        <div>
          <span class="bg-slate-100 px-4 py-2 rounded-full text-sm">
            18 months
          </span>
        </div>

        <div>
          14.0%
        </div>

        <div>
          11 Apr 2026
        </div>

      </div>

      

      <div class="grid grid-cols-7 gap-4 items-center px-8 py-6 border-b border-slate-100 hover:bg-slate-50">

        <div class="col-span-2 font-semibold text-lg">
          Emergency — hospital
        </div>

        <div>
          KES 45,000
        </div>

        <div class="text-green-600 font-bold">
          KES 5,232
        </div>

        <div>
          <span class="bg-slate-100 px-4 py-2 rounded-full text-sm">
            9 months
          </span>
        </div>

        <div>
          11.0%
        </div>

        <div>
          30 Mar 2026
        </div>

      </div>

      

      <div class="grid grid-cols-7 gap-4 items-center px-8 py-6 hover:bg-slate-50">

        <div class="col-span-2 font-semibold text-lg">
          Plot deposit
        </div>

        <div>
          KES 600,000
        </div>

        <div class="text-green-600 font-bold">
          KES 20,507
        </div>

        <div>
          <span class="bg-slate-100 px-4 py-2 rounded-full text-sm">
            36 months
          </span>
        </div>

        <div>
          14.0%
        </div>

        <div>
          14 Feb 2026
        </div>

      </div>

    </div>

  </main>

</div>